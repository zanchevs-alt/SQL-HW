    SELECT
    b.isbn,
    b.title,
    a.author_id,
    a.author_name,
    p.publisher_id,
    p.publisher_name,
    p.publisher_city
FROM books b
JOIN authors    a ON b.author_id    = a.author_id
JOIN publishers p ON b.publisher_id = p.publisher_id;
