-- טבלת סופרים
CREATE TABLE authors (
    author_id   VARCHAR(10) PRIMARY KEY,
    author_name VARCHAR(100) NOT NULL
);

-- טבלת הוצאות לאור
CREATE TABLE publishers (
    publisher_id   VARCHAR(10) PRIMARY KEY,
    publisher_name VARCHAR(100) NOT NULL,
    publisher_city VARCHAR(100) NOT NULL
);

-- טבלת ספרים (עם FK לשתי הטבלאות)
CREATE TABLE books (
    isbn         VARCHAR(20) PRIMARY KEY,
    title        VARCHAR(200) NOT NULL,
    author_id    VARCHAR(10) NOT NULL REFERENCES authors(author_id),
    publisher_id VARCHAR(10) NOT NULL REFERENCES publishers(publisher_id)
);
